{
  "expo": {
    "newArchEnabled": false,
    "name": "Auris AI",
    "slug": "auris-app",
    "scheme": "auris",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aurisai.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "fetch"
        ],
        "NSMicrophoneUsageDescription": "Auris needs microphone access to listen and respond.",
        "NSLocationWhenInUseUsageDescription": "Auris uses your location to suggest nearby places.",
        "NSCalendarsUsageDescription": "Auris can add events to your calendar from conversations.",
        "NSCalendarsFullAccessUsageDescription": "Auris can read and add events to your calendar.",
        "NSCameraUsageDescription": "Auris uses the camera to understand your environment.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050505",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withDevClientBundleURL",
      "expo-router",
      "expo-camera",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Auris uses your location to suggest nearby places."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Auris can add events to your calendar from conversations."
        }
      ],
      "expo-audio",
      [
        "expo-notifications",
        {
          "color": "#C9A84C"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0caa1779-2c93-47e3-84cb-fb040c951eee"
      }
    },
    "owner": "selimfedakar"
  }
}
